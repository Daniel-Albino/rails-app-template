# =============================================================================
# .gitignore - Files ignored by Git
# =============================================================================

# Environment variables (NEVER commit)
.env
.env.local
.env.*.local

# Logs
/log/*
!/log/.keep

# Temporary files
/tmp/*
!/tmp/.keep

# Locally installed gems
/vendor/bundle

# Node modules
/node_modules

# Compiled assets
/public/assets
/public/packs
/public/packs-test

# Storage (uploads, etc.)
/storage/*
!/storage/.keep

# Boot
/tmp/pids/*.pid

# Setup flag
setupcomplete

# IDEs
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Coverage
/coverage

# Byebug history
.byebug_history

# Yarn integrity
.yarn-integrity
