# =============================================================================
# docker/environments/development.env
# Variáveis específicas de desenvolvimento.
# Estas são seguras para commit (não contêm segredos reais).
# =============================================================================

RAILS_ENV=development
NODE_ENV=development

# Logs detalhados em desenvolvimento
RAILS_LOG_LEVEL=debug
RAILS_LOG_TO_STDOUT=true

# Desactiva verificação SSL em dev
DISABLE_SSL=true

# Bootsnap
DISABLE_BOOTSNAP=false

# Better Errors + binding.pry
BETTER_ERRORS_HOST=0.0.0.0

# Mailer — usa Mailpit em desenvolvimento
MAIL_HOST=mailpit
MAIL_PORT=1025
ACTION_MAILER_DEFAULT_URL_HOST=localhost:3000
