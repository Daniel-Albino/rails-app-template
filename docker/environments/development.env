# =============================================================================
# docker/environments/development.env
# Development-specific variables.
# Safe to commit (no real secrets).
# =============================================================================

RAILS_ENV=development
NODE_ENV=development

# Verbose logs in development
RAILS_LOG_LEVEL=debug
RAILS_LOG_TO_STDOUT=true

# Disable SSL checks in development
DISABLE_SSL=true

# Bootsnap
DISABLE_BOOTSNAP=false

# Better Errors + binding.pry
BETTER_ERRORS_HOST=0.0.0.0

# Mailer - use Mailpit in development
MAIL_HOST=mailpit
MAIL_PORT=1025
ACTION_MAILER_DEFAULT_URL_HOST=localhost:3000
