# =============================================================================
# docker/environments/production.env
# Variáveis específicas de produção.
# NÃO coloca segredos aqui — usa o .env ou secrets manager.
# =============================================================================

RAILS_ENV=production
NODE_ENV=production

# Performance
RAILS_LOG_LEVEL=info
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true

# Segurança
FORCE_SSL=true

# Web server concurrency
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5

# Assets
RAILS_ASSET_HOST=

# Mailer — define no .env com variáveis SMTP reais
ACTION_MAILER_DEFAULT_URL_HOST=yourdomain.com
