# =============================================================================
# docker/environments/production.env
# Production-specific variables.
# DO NOT place secrets here - use .env or a secrets manager.
# =============================================================================

RAILS_ENV=production
NODE_ENV=production

# Performance
RAILS_LOG_LEVEL=info
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true

# Security
FORCE_SSL=true

# Web server concurrency
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5

# Assets
RAILS_ASSET_HOST=

# Mailer - set real SMTP variables in .env
ACTION_MAILER_DEFAULT_URL_HOST=yourdomain.com
