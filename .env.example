# =============================================================================
# .env.example - Project environment variables
# Copy this file to .env and update values.
# NEVER commit .env.
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=my_app
APP_PORT=3000

# Rails
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=false
RAILS_MAX_THREADS=5

# Secret key (generate with: bundle exec rails secret)
# In production, use a real secure value.
SECRET_KEY_BASE=your_secret_key_base_here

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=my_app_development
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full URL (optional, takes precedence over individual vars)
# DATABASE_URL=postgresql://postgres:password@db:5432/my_app_development

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# Redis password (production only)
# REDIS_PASSWORD=your_redis_password_here
# In production, use URL with password:
# REDIS_URL=redis://:your_redis_password_here@redis:6379/0

# Sidekiq Web UI (production)
# SIDEKIQ_USERNAME=admin
# SIDEKIQ_PASSWORD=change_me

# =============================================================================
# EMAIL (development uses Mailpit)
# =============================================================================
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@my_app.local

# Production - real SMTP settings
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# SMTP_DOMAIN=yourdomain.com

# =============================================================================
# ACTION CABLE
# =============================================================================
# ACTION_CABLE_ALLOWED_REQUEST_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# ACTIVE STORAGE (optional)
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
# AWS_BUCKET=my_app_production
# ACTIVE_STORAGE_SERVICE=amazon

# =============================================================================
# PRODUCTION - Additional variables
# =============================================================================
# FORCE_SSL=true
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# WEB_CONCURRENCY=2
