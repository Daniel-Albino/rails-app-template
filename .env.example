# =============================================================================
# .env.example — Variáveis de ambiente do projeto
# Copia este ficheiro para .env e preenche os valores.
# NUNCA faças commit do ficheiro .env!
# =============================================================================

# =============================================================================
# APLICAÇÃO
# =============================================================================
APP_NAME=my_app
APP_PORT=3000

# Rails
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=false
RAILS_MAX_THREADS=5

# Chave secreta (gera com: bundle exec rails secret)
# Em produção, OBRIGATÓRIO definir um valor real e seguro!
SECRET_KEY_BASE=your_secret_key_base_here

# =============================================================================
# BASE DE DADOS — PostgreSQL
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=my_app_development
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL completo (opcional, tem precedência sobre as vars individuais)
# DATABASE_URL=postgresql://postgres:password@db:5432/my_app_development

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# Password Redis (apenas em produção)
# REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# EMAIL (desenvolvimento usa Mailpit)
# =============================================================================
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@my_app.local

# Produção — configuração SMTP real
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# SMTP_DOMAIN=yourdomain.com

# =============================================================================
# ACTION CABLE
# =============================================================================
# ACTION_CABLE_ALLOWED_REQUEST_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# ACTIVE STORAGE (opcional)
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
# AWS_BUCKET=my_app_production

# =============================================================================
# PRODUÇÃO — Variáveis adicionais
# =============================================================================
# FORCE_SSL=true
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# WEB_CONCURRENCY=2
